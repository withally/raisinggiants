# Supabase — local dev values (run `supabase start` to get actual keys)
# For local development: copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# Public — safe to expose to the browser bundle
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — must NOT have NEXT_PUBLIC_ prefix (Next.js will not bundle it into the client)
# WARNING: This key bypasses ALL Row Level Security policies.
# Use only in server-side code (e.g., Stripe webhook handler).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
